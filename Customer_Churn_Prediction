    "# Check The How Many Outliers Present In Dataset Using IQR Method\n",
    "outlier_data = churn_df.copy()\n",
    "outlier_box = set()\n",
    "numeric_columns = ['tenure','MonthlyCharges','TotalCharges']\n",
    "\n",
    "for num_cols in numeric_columns:\n",
    "    Q1 = outlier_data[num_cols].quantile(0.25)\n",
    "    Q3 = outlier_data[num_cols].quantile(0.75)\n",
    "    IQR = Q3 - Q1\n",
    "    Lower_Bound = Q1 - 1.5 * IQR\n",
    "    Upper_Bound = Q3 + 1.5 * IQR\n",
    "    outliers = outlier_data[(outlier_data[num_cols] < Lower_Bound) | (outlier_data[num_cols] > Upper_Bound)]\n",
    "    outlier_box.update(outliers.index)\n",
    "    plt.figure(figsize = (4,5))\n",
    "    plt.title(f'Outlier Column {num_cols}')\n",
    "    sns.boxplot(x = outlier_data[num_cols],color = 'orange')\n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "print(\"#=====================================================#\")\n",
    "print(\"#=====================================================#\")\n",
    "print(f'Total: {len(outlier_box)} Outliers Present In Dataset') "
   ]
